# ============================================================
# CARGOTRACK — ENV TEMPLATE
# ============================================================
# Bu dosya git'e commit edilebilir (gerçek secret YOK).
# Production için: cp .env.example .env.production + DOLDUR
# Development için: cp .env.example .env + ayarla
# Secret üretimi: node scripts/generate-secrets.js
# ============================================================

# === Database ===
DB_HOST=127.0.0.1
DB_USER=cargotrack
# 32+ karakter, harf+rakam+sembol. Üret: node scripts/generate-secrets.js
DB_PASSWORD=CHANGE-ME-strong-random-password
DB_NAME=cargotrack
DB_PORT=3306

# === JWT ===
# 64+ karakter rastgele. Üret: node scripts/generate-secrets.js
# CRITICAL: production'da MUTLAKA değiştir, leak'lerse tüm oturumlar tehlikede.
JWT_SECRET=CHANGE-ME-generate-with-scripts-generate-secrets-js
JWT_EXPIRES_IN=8h

# === App ===
NODE_ENV=production
PORT=3000
UPLOAD_DIR=./uploads
BASE_CURRENCY=EUR

# === Admin defaults ===
# ÖNERİLEN (production): bu değişkeni .env.production'da BOŞ bırakın.
# Server başladığında hiç user yoksa şu komutu çalıştırın:
#   node scripts/setup-admin.js
# (interaktif olarak güçlü şifreli süper admin oluşturur — şifre HİÇBİR dosyaya yazılmaz)
#
# Sadece development için (otomatik kurulumda kullanışlı):
# Eğer set edilirse + hiç user yoksa → admin/<bu şifre> ile oluşturulur, ilk girişte zorla değiştirilir.
# Production'da bu yaklaşım da çalışır ama şifre .env dosyasında durur (risk).
DEFAULT_ADMIN_PASSWORD=

# === CORS ===
# Production'da frontend domain'ini buraya yaz (virgülle ayır).
# Boş bırakırsan: development'ta * (her şeye açık), production'da (NODE_ENV=production) sadece same-origin.
# Örnek: CORS_ORIGINS=https://cargotrack.example.com,https://www.cargotrack.example.com
CORS_ORIGINS=

# === HTTPS / Proxy ===
# Reverse proxy (nginx) arkasında çalışıyorsa 1, doğrudan public ise 0.
# 1 → Express req.secure, req.ip vs. X-Forwarded-* header'larına güvenir.
TRUST_PROXY=1
# Production'da true ise: HTTP istekleri otomatik HTTPS'e yönlendirilir (TRUST_PROXY=1 gerekli).
FORCE_HTTPS=true

# === Rate limit ===
LOGIN_MAX_ATTEMPTS=10
LOGIN_WINDOW_MIN=15
API_RATE_LIMIT_PER_MIN=120

# === Email (opsiyonel, bildirim e-posta için) ===
# Boş bırakırsan e-posta gönderimi devre dışı.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="CargoTrack <noreply@example.com>"
